{
  "name": "dp-rapportering",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "react-router build",
    "token": "node token-generator.mjs",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "prepare": "husky",
    "lint": "eslint",
    "validate": "pnpm lint && tsc",
    "test": "vitest",
    "test-coverage": "vitest --coverage",
    "pre-commit": "lint-staged && pnpm run typecheck"
  },
  "dependencies": {
    "@date-fns/tz": "1.4.1",
    "@grafana/faro-web-sdk": "2.6.3",
    "@msw/data": "1.1.6",
    "@navikt/aksel-icons": "8.10.5",
    "@navikt/ds-css": "8.10.5",
    "@navikt/ds-react": "8.10.6",
    "@navikt/nav-dekoratoren-moduler": "3.7.1",
    "@navikt/oasis": "4.1.4",
    "@portabletext/react": "6.2.0",
    "@portabletext/types": "4.0.2",
    "@react-router/express": "7.15.1",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@rvf/react-router": "8.1.2",
    "@rvf/zod": "7.0.5",
    "@sanity/client": "7.22.0",
    "classnames": "2.5.1",
    "compression": "1.8.1",
    "cookie": "^1.1.1",
    "cross-env": "10.1.0",
    "date-fns": "4.2.1",
    "express": "5.2.1",
    "groq": "5.25.1",
    "html-react-parser": "6.1.1",
    "isbot": "5.1.40",
    "morgan": "1.10.1",
    "msw": "2.14.6",
    "prom-client": "15.1.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1",
    "remeda": "2.34.1",
    "tiny-invariant": "1.3.3",
    "tinyduration": "3.4.1",
    "uuidv7": "1.2.1",
    "winston": "3.19.0",
    "zod": "4.4.3",
    "zod-form-data": "3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@inquirer/prompts": "8.4.3",
    "@react-router/dev": "7.15.1",
    "@react-router/fs-routes": "7.15.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-istanbul": "4.1.6",
    "dotenv": "17.4.2",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --list-different",
      "eslint --max-warnings 0",
      "bash -c tsc",
      "bash -c 'pnpm lint'"
    ]
  }
}
